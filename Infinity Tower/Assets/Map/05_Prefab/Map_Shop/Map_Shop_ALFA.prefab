  NPCName: "\uC0C1\uC778"
  dialogueLines:
  - "\uC774 \uD0D1\uC744 \uC5EC\uD589\uD558\uB294 \uBAA8\uD5D8\uAC00\uAD6C\uB098?"
  - "\uAC12\uC9C4\uAC70\uB77C\uB3C4 \uC788\uC5B4?"
  - "\uC7A5\uBE44\uB3C4 \uC88B\uACE0 \uBAAC\uC2A4\uD130\uC758 \uC804\uB9AC\uD488\uC774\uC5EC\uB3C4
