  NPCName: "\uB9C8\uB140"
  dialogueLines:
  - "\uC548\uB155 \uB098\uB294 \uB9C8\uB140\uB77C\uACE0 \uD574"
  - "\uBCF4\uC544\uD558\uB2C8 \uCCB4\uB825\uC774 \uB2E4 \uB5A8\uC5B4\uC9C4\uAC70
    \uAC19\uC740\uB370\n\uC5EC\uAE30\uC11C \uD68C\uBCF5\uD558\uACE0 \uAC00"
  - "\uB0B4\uAC00 \uC81C\uC870\uD55C \uBB3C\uC57D\uC744 \uB9C8\uC2DC\uBA74 \n\uCCB4\uB825\uC774
    \uD68C\uBCF5\uB418\uBA74\uC11C \uCCB4\uB825\uC774 \uC99D\uAC00\uD560\uAC70\uC57C"
  addDialogueLine:
  - "\uC5EC\uAE30\uAC00 \uC5B4\uB518\uC9C0 \uC544\uB0D0\uACE0?"
  - "\uB098\uB3C4 \uC798 \uBAB0\uB77C\n\uB09C \uB9C8\uB140 \uB9C8\uC744\uC5D0\uC11C
    \uAC11\uC790\uAE30 \uC5EC\uAE30\uB85C \uC654\uAC70\uB4E0"
  - "\uD558\uC9C0\uB9CC \uADF8\uAC74 \uC54C\uC544\n\uB0B4\uAC00 \uB4E3\uAE30\uB85C\uB294
    \uC5EC\uAE30\uB294 \n\uC2DC\uAC04\uACFC \uACF5\uAC04\uC774 \uB2E4\uB974\uB2E4\uACE0
    \uD558\uB354\uB77C\uACE0"
  selectAText: "\uAD6C\uB9E4 \uD558\uAE30"
  selectBText: "\uC815\uBCF4 \uBB3B\uAE30"
