  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ShopNPC
  NPCName: "\uB300\uC7A5\uC7A5\uC774"
  dialogueLines:
  - "\uC774\uBD10 \uC80A\uC740\uC774 \uC7A5\uBE44\uB97C \uAC15\uD654\uD560 \uC0DD\uAC01
    \uC5C6\uB098?"
  addDialogueLine:
  - "\uC774 \uD0D1\uC774 \uBB34\uC5C8\uC778\uC9C0\uB294 \uB098\uB3C4 \uC798 \uBAA8\uB974\uACA0\uB124\n\uB300\uC2E0
    \uC5EC\uAE30\uB97C \uC18C\uAC1C\uD574\uC8FC\uACA0\uB124\n\uC5EC\uAE30\uB294 \uB0B4
    \uB300\uC7A5\uAC04\uC774\uB77C\uB124"
  - "\uC5EC\uAE30\uC11C\uB294 \uC7A5\uBE44\uB97C \uAC15\uD654\uD560 \uC218 \uC788\uC9C0\n\uD558\uC9C0\uB9CC
    \uB098\uB294 \uC790\uC6D0 \uBD09\uC0AC\uC790\uAC00 \uC544\uB2C8\uB77C\uB124 "
  - "\uC7A5\uBE44\uB97C \uAC15\uD654\uD558\uACE0 \uC2F6\uB2E4\uBA74\n\uB3C8\uACFC
    \uAC15\uD654\uC11D\uC744 \uAC00\uC838\uC624\uAC8C\n\uADF8\uB7EC\uBA74 \uC7A5\uBE44\uB97C
    \uAC15\uD654\uC2DC\uCF1C\uC8FC\uB3C4\uB85D \uD558\uACA0\uB124"
  selectAText: "\uAC15\uD654 \uD558\uAE30"
